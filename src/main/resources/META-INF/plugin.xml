<idea-plugin>
    <!-- id / name / vendor / description 는 build.gradle.kts 의 pluginConfiguration 에서 주입됨 -->

    <!-- 모든 IntelliJ 계열 IDE(Rider 포함)에서 동작하는 순수 플랫폼 플러그인 -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="Claude Config"
            anchor="right"
            icon="/icons/claude.svg"
            factoryClass="com.gear2w.claudeconfig.ClaudeConfigToolWindowFactory"/>

        <!-- CLAUDE.md 의 @경로 import 자동완성 -->
        <completion.contributor
            language="any"
            implementationClass="com.gear2w.claudeconfig.ClaudeImportCompletionContributor"/>

        <!-- CLAUDE.md 의 @경로 import 존재 검증 (없으면 빨간 밑줄) -->
        <annotator
            language="any"
            implementationClass="com.gear2w.claudeconfig.ClaudeImportAnnotator"/>
    </extensions>
</idea-plugin>
